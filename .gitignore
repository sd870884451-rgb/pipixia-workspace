# 皮皮虾工作区 - .gitignore

# OpenClaw 运行时（不含配置文件）
.openclaw/

# 临时调试脚本
_analyze*  _check*  _diag*  _dl*  _do*  _enhance*  _fix*  _full*  _gen*
_img*  _log*  _ocr*  _push*  _read*  _scan*  _search*  _sync*  _thumb*
_tmp*  _verify*  debug_html*  fix_cdn*  wait_port*  check_port*  check_deploy*
.consolidate-state.json  BOOTSTRAP.md

# Python 分析脚本
*.py

# 图片 / 媒体文件
*.png  *.jpg  *.jpeg  *.gif  *.webp  *.ico

# Three.js 打包文件（从 CDN 重新生成）
three_bundled.js  three_bundled.min.js

# 备份文件
*.bak

# 依赖（npm / node_modules）
node_modules/  ClawLibrary/node_modules/